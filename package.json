{
  "name": "@featurevisor/roku",
  "version": "1.1.4",
  "description": "Roku FeatureVisor SDK",
  "keywords": [
    "brightscript",
    "kopytko",
    "kopytko-module",
    "roku",
    "featurevisor",
    "feature",
    "features",
    "flags",
    "feature flags",
    "feature toggles",
    "feature management",
    "experimentation",
    "experiment",
    "experiments"
  ],
  "author": "Błażej Chełkowski <bchelkow@gmail.com>",
  "files": [
    "src",
    "!**/_tests"
  ],
  "scripts": {
    "format": "kopytko-format --write \"src/**/*.brs\"",
    "format:check": "kopytko-format --check \"src/**/*.brs\"",
    "lint": "kopytko-lint --check --source-dir src",
    "lint:fix": "kopytko-lint --fix --source-dir src",
    "test": "node node_modules/@dazn/kopytko-unit-testing-framework/scripts/test.js"
  },
  "dependencies": {
    "@dazn/kopytko-framework": "^3.4.2",
    "@dazn/kopytko-utils": "^2.8.1",
    "compare-versions-roku": "^1.0.2",
    "murmurhash-roku": "^1.0.1"
  },
  "devDependencies": {
    "@dazn/kopytko-unit-testing-framework": "^2.6.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "kopytko-formatter": "^1.1.5",
    "kopytko-linter": "^1.4.0",
    "semantic-release": "^25.0.5"
  },
  "license": "MIT",
  "kopytkoModuleDir": "src/",
  "repository": {
    "type": "git",
    "url": "https://github.com/featurevisor/featurevisor-roku.git"
  },
  "bugs": {
    "url": "https://github.com/featurevisor/featurevisor-roku/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": true,
          "provenance": true
        }
      ],
      "@semantic-release/changelog",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "package-lock.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
